{
  "name": "nodetrace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node --watch apps/server/index.js\" \"vite --config apps/renderer/vite.config.js --host 0.0.0.0\"",
    "dev:client": "vite --config apps/renderer/vite.config.js --host 0.0.0.0",
    "dev:server": "node --watch apps/server/index.js",
    "desktop:dev": "concurrently \"npm run dev:client\" \"electron apps/desktop/main.js --dev-url=http://127.0.0.1:5173\"",
    "desktop:start": "electron apps/desktop/main.js",
    "server": "node apps/server/index.js",
    "serve:shared": "node apps/server/index.js",
    "build": "vite build --config apps/renderer/vite.config.js",
    "lint": "eslint .",
    "preview": "vite preview --config apps/renderer/vite.config.js --host 0.0.0.0",
    "start": "node apps/server/index.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "vite": "^7.3.1"
  }
}
